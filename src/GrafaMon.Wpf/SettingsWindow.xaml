<Window x:Class="GrafaMon.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GrafaMon Settings"
        Width="600"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#2B2B2B" BorderBrush="#555">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2B2B2B"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="#555" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Connection Tab -->
            <TabItem Header="Connection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Grafana Connection Settings" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="Grafana Base URL *" Foreground="#CCC" Margin="0,5,0,3"/>
                        <TextBox Name="TxtGrafanaBaseUrl" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="The base URL of your Grafana instance (e.g., https://grafana.example.com)"/>

                        <TextBlock Text="API Key *" Foreground="#CCC" Margin="0,10,0,3"/>
                        <PasswordBox Name="PwdApiKey" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                     ToolTip="Grafana Service Account API token with Viewer permissions"/>

                        <TextBlock Text="Organization ID *" Foreground="#CCC" Margin="0,10,0,3"/>
                        <TextBox Name="TxtOrgId" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="Grafana organization ID (default is 1)"/>

                        <TextBlock Text="Active Alerts Path *" Foreground="#CCC" Margin="0,10,0,3"/>
                        <TextBox Name="TxtActiveAlertsPath" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="API endpoint path for fetching active alerts"/>

                        <TextBlock Text="Polling Interval (seconds) *" Foreground="#CCC" Margin="0,10,0,3"/>
                        <TextBox Name="TxtPollingInterval" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="How often to poll Grafana for alerts (minimum 5 seconds)"/>

                        <Button Name="BtnTestConnection" Content="Test Connection" Width="150" HorizontalAlignment="Left" Margin="0,15,0,0" 
                                Padding="10,5" Click="OnTestConnectionClick" Background="#0078D4" Foreground="White" BorderThickness="0"/>

                        <TextBlock Name="TxtConnectionStatus" 
                                   Foreground="#4CAF50" 
                                   FontSize="12"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" 
                                   Visibility="Collapsed"
                                   MinHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- UI Settings Tab -->
            <TabItem Header="UI Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="User Interface Settings" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="Maximum Alert Detail Rows" Foreground="#CCC" Margin="0,5,0,3"/>
                        <TextBox Name="TxtMaxAlertDetailRows" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="Maximum number of alert rows to display in the detail window (minimum 1)"/>
                        <TextBlock Text="Controls the scrollable height of the alert detail table" Foreground="#888" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Sound Settings Tab -->
            <TabItem Header="Sound">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Sound Notification Settings" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox Name="ChkEnableSoundNotifications" Content="Enable Sound Notifications" Foreground="White" Margin="0,5,0,10" 
                                  Checked="OnEnableSoundChanged" Unchecked="OnEnableSoundChanged"/>

                        <TextBlock Text="Custom Sound File Path (optional)" Foreground="#CCC" Margin="0,5,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Name="TxtSoundFilePath" Grid.Column="0" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                     ToolTip="Path to custom .wav sound file (leave empty for Windows default sound)"/>
                            <Button Name="BtnBrowseSound" Grid.Column="1" Content="Browse..." Margin="5,0,0,0" Padding="10,4" Click="OnBrowseSoundClick" 
                                    Background="#444" Foreground="White" BorderBrush="#555"/>
                        </Grid>
                        <TextBlock Text="Leave empty to use Windows default critical alert sound. Only .wav files are supported." 
                                   Foreground="#888" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Logging Tab -->
            <TabItem Header="Logging">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Logging Settings" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox Name="ChkEnableLogging" Content="Enable Logging" Foreground="White" Margin="0,5,0,10"/>

                        <TextBlock Text="Log Level" Foreground="#CCC" Margin="0,5,0,3"/>
                        <ComboBox Name="CmbLogLevel" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4">
                            <ComboBox.Template>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <ToggleButton Name="ToggleButton" 
                                                      Grid.Column="2" 
                                                      Focusable="false"
                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      ClickMode="Press"
                                                      Background="#333"
                                                      BorderBrush="#555">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition />
                                                            <ColumnDefinition Width="20" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border x:Name="Border" 
                                                                Grid.ColumnSpan="2"
                                                                CornerRadius="3"
                                                                Background="#333"
                                                                BorderBrush="#555"
                                                                BorderThickness="1" />
                                                        <Path x:Name="Arrow"
                                                              Grid.Column="1"     
                                                              Fill="White"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M 0 0 L 4 4 L 8 0 Z"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter Name="ContentSite"
                                                          IsHitTestVisible="False" 
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                          Margin="6,3,23,3"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left">
                                            <ContentPresenter.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </ContentPresenter.Resources>
                                        </ContentPresenter>
                                        <Popup Name="Popup"
                                               Placement="Bottom"
                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                               AllowsTransparency="True" 
                                               Focusable="False"
                                               PopupAnimation="Slide">
                                            <Grid Name="DropDown"
                                                  SnapsToDevicePixels="True"                
                                                  MinWidth="{TemplateBinding ActualWidth}"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                <Border x:Name="DropDownBorder"
                                                        Background="#333"
                                                        BorderThickness="1"
                                                        BorderBrush="#555"/>
                                                <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </ComboBox.Template>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#333"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border Name="Border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#444"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#444"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Information"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                            <ComboBoxItem Content="Fatal"/>
                        </ComboBox>

                        <TextBlock Text="Maximum Log File Size (MB)" Foreground="#CCC" Margin="0,10,0,3"/>
                        <TextBox Name="TxtMaxLogFileSizeMB" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="Maximum size per log file in megabytes (minimum 1)"/>

                        <TextBlock Text="Maximum Log File Count" Foreground="#CCC" Margin="0,10,0,3"/>
                        <TextBox Name="TxtMaxLogFileCount" Background="#333" Foreground="White" BorderBrush="#555" Padding="6,4" 
                                 ToolTip="Maximum number of log files to retain (minimum 1)"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Name="BtnSave" Content="Save" Width="80" Padding="10,5" Click="OnSaveClick" 
                    Background="#0078D4" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Name="BtnCancel" Content="Cancel" Width="80" Padding="10,5" Click="OnCancelClick" 
                    Background="#444" Foreground="White" BorderBrush="#555"/>
        </StackPanel>
    </Grid>
</Window>
