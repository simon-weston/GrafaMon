<Window x:Class="GrafaMon.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:local="clr-namespace:GrafaMon.Wpf"
        Title="Grafana Alerts"
        Width="200" Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Hide any toolbars -->
        <Style TargetType="ToolBar">
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>

        <!-- Converter for severity to background color -->
        <local:SeverityToBackgroundConverter x:Key="SeverityToBackgroundConverter"/>

        <!-- Flashing animation for critical alerts -->
        <Storyboard x:Key="FlashingStoryboard" RepeatBehavior="Forever">
            <ColorAnimation 
                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                    From="#660000"
                    To="#FF0000"
                    Duration="0:0:0.4"
                    AutoReverse="True" />
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Summary widget (always visible)  -->
        <Border x:Name="RootBorder"
            CornerRadius="10"
            Padding="10,6"
            Grid.Row="0"
            BorderThickness="2">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- Default background from binding -->
                    <Setter Property="Background" Value="{Binding SummaryBackground}"/>
                    <!-- Default border brush -->
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Style.Triggers>
                        <!-- When FlashCritical is True, override background and start flashing -->
                        <DataTrigger Binding="{Binding FlashCritical}" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#A00000"/>
                                </Setter.Value>
                            </Setter>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Name="FlashStoryboard" Storyboard="{StaticResource FlashingStoryboard}" />
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="FlashStoryboard" />
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                        <!-- When HasPollingError is True, change border to orange and show error tooltip -->
                        <DataTrigger Binding="{Binding HasPollingError}" Value="True">
                            <Setter Property="BorderBrush" Value="#FFA500"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.ToolTip>
                <ToolTip>
                    <ToolTip.Style>
                        <Style TargetType="ToolTip">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPollingError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ToolTip.Style>
                    <StackPanel>
                        <TextBlock Text="Polling Error" FontWeight="Bold" Foreground="#FFA500"/>
                        <TextBlock Text="{Binding LastPollingError}" MaxWidth="300" TextWrapping="Wrap"/>
                    </StackPanel>
                </ToolTip>
            </Border.ToolTip>
            <TextBlock Text="{Binding DisplayText}"
                   Foreground="White"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        </Border>
        <!-- Details popup (does not resize the window) -->
        <Popup x:Name="DetailsPopup"
            AllowsTransparency="True"
            Placement="Right"
            StaysOpen="True"
            PopupAnimation="Fade">
                 <Border x:Name="DetailsPanel"
             Background="#2B2B2B"
             BorderBrush="#555"
             BorderThickness="1"
             CornerRadius="6"
             Padding="6"
             Margin="0,2,0,0"
             MinWidth="450"
             MaxWidth="1000"
             MaxHeight="500">
                     <Grid>
                         <Grid.RowDefinitions>
                             <RowDefinition Height="Auto"/>
                             <RowDefinition Height="*"/>
                         </Grid.RowDefinitions>

                         <!-- Filter UI -->
                         <Border Grid.Row="0" 
                     Background="#1E1E1E" 
                     BorderBrush="#444" 
                     BorderThickness="0,0,0,1" 
                     Padding="8,6"
                     Margin="0,0,0,4">
                             <Grid>
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="*"/>
                                 </Grid.ColumnDefinitions>

                                 <!-- Severity Checkboxes -->
                                 <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                     <TextBlock Text="Show:" 
                                    Foreground="#AAA" 
                                    FontSize="11" 
                                    VerticalAlignment="Center" 
                                    Margin="0,0,8,0"/>

                                     <CheckBox Content="🔥 Critical" 
                                   IsChecked="{Binding FilterCritical}" 
                                   Foreground="White" 
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"/>

                                     <CheckBox Content="⚠️ Warning" 
                                   IsChecked="{Binding FilterWarning}" 
                                   Foreground="White" 
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"/>

                                     <CheckBox Content="ℹ️ Info" 
                                   IsChecked="{Binding FilterInfo}" 
                                   Foreground="White" 
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"/>
                                 </StackPanel>

                                 <!-- Search TextBox -->
                                 <TextBox x:Name="SearchTextBox"
                              Grid.Column="1" 
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                              Background="#333" 
                              Foreground="White" 
                              BorderBrush="#555" 
                              BorderThickness="1" 
                              Padding="6,4" 
                              FontSize="11" 
                              VerticalAlignment="Center"
                              HorizontalAlignment="Stretch">
                                     <TextBox.Style>
                                         <Style TargetType="TextBox">
                                             <Style.Triggers>
                                                 <Trigger Property="Text" Value="">
                                                     <Setter Property="Background" Value="#333"/>
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBox.Style>
                                     <TextBox.Resources>
                                         <!-- Placeholder text -->
                                         <VisualBrush x:Key="PlaceholderBrush" 
                                          AlignmentX="Left" 
                                          AlignmentY="Center" 
                                          Stretch="None">
                                             <VisualBrush.Visual>
                                                 <TextBlock Text="🔍 Search alerts..." 
                                                Foreground="#777" 
                                                FontSize="11" 
                                                Margin="2,0,0,0"/>
                                             </VisualBrush.Visual>
                                         </VisualBrush>
                                     </TextBox.Resources>
                                     <TextBox.Template>
                                         <ControlTemplate TargetType="TextBox">
                                             <Grid>
                                                 <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="{TemplateBinding BorderThickness}" 
                                             CornerRadius="3">
                                                     <ScrollViewer x:Name="PART_ContentHost" 
                                                       Margin="{TemplateBinding Padding}"/>
                                                 </Border>
                                                 <Border x:Name="PlaceholderBorder" 
                                             Background="{StaticResource PlaceholderBrush}" 
                                             IsHitTestVisible="False" 
                                             Margin="6,0,0,0">
                                                     <Border.Style>
                                                         <Style TargetType="Border">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                     <Setter Property="Visibility" Value="Visible"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Border.Style>
                                                 </Border>
                                             </Grid>
                                         </ControlTemplate>
                                     </TextBox.Template>
                                 </TextBox>
                             </Grid>
                         </Border>

                         <!-- DataGrid (existing code) -->
                         <DataGrid Grid.Row="1"
                       x:Name="AlertsDataGrid"
                       ItemsSource="{Binding AlertDetails}"
                       AutoGenerateColumns="False"
                       HeadersVisibility="Column"
                       RowHeaderWidth="0"
                       CanUserResizeRows="False"
                       CanUserResizeColumns="False"
                       IsReadOnly="True"
                       FontSize="12"
                       Background="#2B2B2B"
                       Foreground="White"
                       RowBackground="Transparent"
                       AlternatingRowBackground="Transparent"
                       GridLinesVisibility="Horizontal"
                       HorizontalGridLinesBrush="#444"
                       SelectionMode="Single"
                       SelectionUnit="FullRow"
                       ScrollViewer.VerticalScrollBarVisibility="Visible"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       Margin="0,0,8,0"
                       LoadingRow="OnAlertsGridLoadingRow"
                       MouseDoubleClick="OnAlertRowDoubleClick">

                             <!-- Keep all existing DataGrid.Resources, ColumnHeaderStyle, RowStyle, and Columns exactly as they are -->
                             <DataGrid.Resources>
                                 <!-- Base cell style: severity background + row hover highlighting -->
                                 <Style TargetType="DataGridCell">
                                     <Setter Property="BorderThickness" Value="0"/>
                                     <Setter Property="Foreground" Value="White"/>
                                     <Setter Property="Background" Value="{Binding SeverityNormalized, Converter={StaticResource SeverityToBackgroundConverter}}"/>
                                     <Style.Triggers>
                                         <!-- Severity-aware hover: critical -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="critical"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#FF0000"/>
                                             <Setter Property="Foreground" Value="White"/>
                                         </MultiDataTrigger>
                                         <!-- Severity-aware hover: warning -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="warning"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#FFA500"/>
                                             <Setter Property="Foreground" Value="Black"/>
                                         </MultiDataTrigger>
                                         <!-- Severity-aware hover: info -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="info"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#1E90FF"/>
                                             <Setter Property="Foreground" Value="White"/>
                                         </MultiDataTrigger>
                                     </Style.Triggers>

                                 </Style>

                                 <!-- Centered cell style (for specific columns) -->
                                 <Style TargetType="DataGridCell" x:Key="CenteredCell">
                                     <Setter Property="BorderThickness" Value="0"/>
                                     <Setter Property="Foreground" Value="White"/>
                                     <Setter Property="Background" Value="{Binding SeverityNormalized, Converter={StaticResource SeverityToBackgroundConverter}}"/>
                                     <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                     <Style.Triggers>
                                         <!-- Severity-aware hover: critical -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="critical"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#FF0000"/>
                                             <Setter Property="Foreground" Value="White"/>
                                         </MultiDataTrigger>
                                         <!-- Severity-aware hover: warning -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="warning"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#FFA500"/>
                                             <Setter Property="Foreground" Value="Black"/>
                                         </MultiDataTrigger>
                                         <!-- Severity-aware hover: info -->
                                         <MultiDataTrigger>
                                             <MultiDataTrigger.Conditions>
                                                 <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                                                 <Condition Binding="{Binding SeverityNormalized}" Value="info"/>
                                             </MultiDataTrigger.Conditions>
                                             <Setter Property="Background" Value="#1E90FF"/>
                                             <Setter Property="Foreground" Value="White"/>
                                         </MultiDataTrigger>
                                     </Style.Triggers>
                                 </Style>

                                 <!-- Style the column headers (default)  -->
                                 <!-- Default header style (left aligned) -->
                                 <Style TargetType="DataGridColumnHeader" x:Key="DefaultColumnHeader">
                                     <Setter Property="Background" Value="Black"/>
                                     <Setter Property="Foreground" Value="White"/>
                                     <Setter Property="FontWeight" Value="Bold"/>
                                     <Setter Property="Padding" Value="8,4"/>
                                     <Setter Property="BorderBrush" Value="#444"/>
                                     <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                     <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                     <Setter Property="Template">
                                         <Setter.Value>
                                             <ControlTemplate TargetType="DataGridColumnHeader">
                                                 <Border Background="Black"
                                             BorderBrush="{TemplateBinding BorderBrush}"
                                             BorderThickness="{TemplateBinding BorderThickness}"
                                             Padding="{TemplateBinding Padding}">
                                                     <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                           VerticalAlignment="Center"/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Setter.Value>
                                     </Setter>
                                 </Style>
                                 <!-- Centered header style (for specific columns) -->
                                 <Style TargetType="DataGridColumnHeader" x:Key="CenteredColumnHeader">
                                     <Setter Property="Background" Value="Black"/>
                                     <Setter Property="Foreground" Value="White"/>
                                     <Setter Property="FontWeight" Value="Bold"/>
                                     <Setter Property="Padding" Value="8,4"/>
                                     <Setter Property="BorderBrush" Value="#444"/>
                                     <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                     <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                     <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                     <Setter Property="Template">
                                         <Setter.Value>
                                             <ControlTemplate TargetType="DataGridColumnHeader">
                                                 <Border Background="Black"
                                             BorderBrush="{TemplateBinding BorderBrush}"
                                             BorderThickness="{TemplateBinding BorderThickness}"
                                             Padding="{TemplateBinding Padding}">
                                                     <ContentPresenter HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Setter.Value>
                                     </Setter>
                                 </Style>
                             </DataGrid.Resources>

                             <DataGrid.ColumnHeaderStyle>
                                 <StaticResource ResourceKey="DefaultColumnHeader"/>
                             </DataGrid.ColumnHeaderStyle>

                             <!-- Style the rows -->
                             <DataGrid.RowStyle>
                                 <Style TargetType="DataGridRow">
                                     <Setter Property="Foreground" Value="White"/>
                                     <Setter Property="Background" Value="Transparent"/>
                                     <!-- Default fallback -->

                                     <!-- Remove default selection highlighting -->
                                     <Setter Property="BorderThickness" Value="0"/>

                                     <Style.Triggers>
                                         <!-- Severity-based backgrounds -->
                                         <DataTrigger Binding="{Binding SeverityNormalized}" Value="critical">
                                             <Setter Property="Background" Value="#8B0000"/>
                                         </DataTrigger>
                                         <DataTrigger Binding="{Binding SeverityNormalized}" Value="warning">
                                             <Setter Property="Background" Value="#B8860B"/>
                                         </DataTrigger>
                                         <DataTrigger Binding="{Binding SeverityNormalized}" Value="info">
                                             <Setter Property="Background" Value="#00008B"/>
                                         </DataTrigger>

                                         <!-- Override selection background to maintain severity colors -->
                                         <Trigger Property="IsSelected" Value="True">
                                         </Trigger>
                                     </Style.Triggers>
                                 </Style>
                             </DataGrid.RowStyle>
                             <!-- Columns -->
                             <DataGrid.Columns>
                                 <DataGridTextColumn Header="Env" 
                                         Binding="{Binding Environment}" 
                                         Width="Auto"
                                         CellStyle="{StaticResource CenteredCell}"/>

                                 <DataGridTextColumn Header="Check" 
                                         Binding="{Binding MonitorTest}" 
                                         Width="Auto"/>

                                 <DataGridTextColumn Header="Host" 
                                         Binding="{Binding Host}" 
                                         Width="Auto"/>

                                 <DataGridTextColumn Header="Summary" 
                                         Binding="{Binding Summary}" 
                                         Width="*"/>

                                 <DataGridTextColumn Header="Severity" 
                                         Binding="{Binding SeverityNormalized}" 
                                         Width="Auto"
                                         CellStyle="{StaticResource CenteredCell}"/>

                                 <DataGridTextColumn Header="Last Updated" 
                                         Binding="{Binding LastUpdatedUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                                         Width="150"
                                         CellStyle="{StaticResource CenteredCell}"/>

                                 <DataGridTextColumn Header="Active For" 
                                         Binding="{Binding ActiveForFormatted}" 
                                         Width="Auto"
                                         CellStyle="{StaticResource CenteredCell}"/>
                             </DataGrid.Columns>
                         </DataGrid>
                     </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>